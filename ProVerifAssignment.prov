free net. (* public network/channel *)
free A, B, C, compA, compC. (* identifiers *)
free request_m, success_m. (* public messages *)
private free flagA, flagB, flagC.
private free s. (* secret *)

(* Section defining the functions used. *)
fun pk/1.
fun h/1.
fun enc/2.
fun sign/2.
private fun sk/1.
reduc dec( enc( x, pk(y)), y) = x.
reduc verify( sign( x, y),pk( y)) = x.
reduc eq(x,x) = x.

(* Queries: what do we want proverif to check *)
query attacker: s.
query attacker: flagA.
query attacker: flagB.
query attacker: flagC.

(* Authentication *)
query evinj:end( x, y, z) ==> evinj:begin( x, y, z).  (* Injective Agreement*)


(* Protocol ------------------------------------------------------------------*)

(* Charlie requests Alice and Bob to prove that they know the same secret s *)
let initiatorC = new nc;
(* Request Alice *)
  out ( net, enc(( A, nc, request_m), pk( sk( A))));
  (* Unpack hash of secret of Alice *)
  in ( net, x);                                       (* C receives x from A *)
    let ( =A, y) = dec( x, sk( C)) in                 (* decrypts x *)
      let ( sa, na) = verify( y , pk( sk( A))) in     (* checks signature *)
        event end( A, C, nc);
(* Request Bob *)
  out ( net, enc(( B, nc, request_m), pk( sk( B))));
  (* Unpack hash of secret of Bob *)
  in ( net, x);                                       (* C reveives x from B *)
    let ( =B, y) = dec( x, sk( C)) in                 (* decrypts x *)
      let ( sb, nb) = verify( y , pk( sk( B))) in     (* checks signature *)
        event end( B, C, nc);
(* Compare hashes of secrets *)
  (*let ok = eq( sa, sb);                               (* checks sa == sb *)
  (*out ( net, enc(( success_m, na), pk( sk( A))));
  out ( net, enc(( success_m, nb), pk( sk( B))));*)
  out ( net, flagC).

let responderA = in( net, x);
  let ( =A, nc, =request_m) = dec(x, sk( A)) in
    event begin( A, C, nc);
  (* Send hashed secret *)
  new na;
  out ( net, enc( ( A, sign( (h( s), na), sk( A))), pk( sk( C))));
  (*in ( net, y);
  let ( =success_m, =na) = dec(y, sk( A));*)
  out ( net, flagA).

let responderB = in( net, x);
  let ( =B, nc, =request_m) = dec(x, sk( B)) in
    event begin( B, C, nc);
  (* Send hashed secret *)
  new nb;
  out ( net, enc( ( B, sign( (h( s), nb), sk( B))), pk( sk( C))));
  (*in ( net, ( =success_m, =nb));*)
  out ( net, flagB).

process
  (!responderA | !responderB | !initiatorC)
